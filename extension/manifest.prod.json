{
  "manifest_version": 3,
  "name": "__APP_NAME__",
  "version": "1.0.0",
  "description": "Shows a floating meaning card for selected text using backend data.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "__API_HOST_PERMISSION__",
    "https://cdn.jsdelivr.net/*",
    "https://tessdata.projectnaptha.com/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "sandbox": {
    "pages": ["sandbox/ocr.html"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles/popup.css"],
      "js": [
        "config/config.js",
        "utils/logger.js",
        "utils/sanitize.js",
        "content/ui.js",
        "content/popup.js",
        "content/selection.js",
        "content/state/popupState.js",
        "content/services/runtime.js",
        "content/content.js",
        "utils/ocr.js",
        "content/imageScan.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sandbox/ocr.html", "sandbox/ocr.js", "config/config.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; child-src 'self' blob: https://cdn.jsdelivr.net; connect-src https://cdn.jsdelivr.net https://tessdata.projectnaptha.com;"
  },
  "externally_connectable": {
    "matches": ["__WEB_APP_MATCH__"]
  }
}
