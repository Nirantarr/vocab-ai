{
  "manifest_version": 3,
  "name": "VocabAI Selection Helper",
  "version": "1.0.0",
  "description": "Shows a floating meaning card for selected text using backend data.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:5000/*"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles/popup.css"],
      "js": [
        "content/ui.js",
        "content/popup.js",
        "content/selection.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["http://localhost:5173/*"]
  }
}
